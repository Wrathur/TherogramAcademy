<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wrathur.course.mapper.StudentHomeworkMapper">
    <select id="selectHomeworkIdsByCourseIds" resultType="java.lang.Integer">
        select id from homework where course_id in
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
        and course_id = true
    </select>
</mapper>